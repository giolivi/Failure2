   "source": [
    "from scipy import stats\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "MATERIAL_COL = 'failure_material'\n",
    "AGE_COL      = 'age'\n",
    "BIN_WIDTH    = 5\n",
    "MAX_AGE      = 150\n",
    "MIN_SAMPLES  = 10\n",
    "\n",
    "bins = np.arange(0, MAX_AGE + BIN_WIDTH, BIN_WIDTH)\n",
    "t    = np.linspace(0, MAX_AGE, 500)\n",
    "\n",
    "candidates = {\n",
    "    'Weibull':     stats.weibull_min,\n",
    "    'Lognormal':   stats.lognorm,\n",
    "    'Normal':      stats.norm,\n",
    "    'Gamma':       stats.gamma,\n",
    "    'Exponential': stats.expon\n",
    "}\n",
    "\n",
    "# ── Step 1: Fit best distribution per material ────────────────────────────────\n",
    "fit_results = {}\n",
    "\n",
    "for material in sorted(merged[MATERIAL_COL].unique()):\n",
    "    subset = merged.loc[merged[MATERIAL_COL] == material, AGE_COL].dropna()\n",
    "\n",
    "    if len(subset) < MIN_SAMPLES:\n",
    "        print(f'{material}: skipped (n={len(subset)})')\n",
    "        continue\n",
    "\n",
    "    best_name, best_params, best_dist, best_aic = None, None, None, np.inf\n",
    "\n",
    "    for name, dist in candidates.items():\n",
    "        try:\n",
    "            params         = dist.fit(subset, floc=0)\n",
    "            log_likelihood = np.sum(dist.logpdf(subset, *params))\n",
    "            aic            = 2 * len(params) - 2 * log_likelihood\n",
    "\n",
    "            if aic < best_aic:\n",
    "                best_aic, best_name, best_params, best_dist = aic, name, params, dist\n",
    "        except Exception:\n",
    "            continue\n",
    "\n",
    "    fit_results[material] = {\n",
    "        'dist': best_dist, 'name': best_name,\n",
    "        'params': best_params, 'aic': best_aic, 'n': len(subset)\n",
    "    }\n",
    "    print(f'{material}: best fit → {best_name}  (AIC={best_aic:.1f}, n={len(subset)})')\n",
    "\n",
    "# ── Step 2: Empirical PDF + fitted PDF overlay ────────────────────────────────\n",
    "n_materials = len(fit_results)\n",
    "n_cols = 3\n",
    "n_rows = (n_materials + n_cols - 1) // n_cols\n",
    "\n",
    "fig1, axes1 = plt.subplots(n_rows, n_cols, figsize=(15, 10))\n",
    "axes1 = axes1.flatten()\n",
    "\n",
    "for idx, (material, res) in enumerate(fit_results.items()):\n",
    "    ax     = axes1[idx]\n",
    "    subset = merged.loc[merged[MATERIAL_COL] == material, AGE_COL].dropna()\n",
    "\n",
    "    counts, edges, patches = ax.hist(\n",
    "        subset, bins=bins, density=True,\n",
    "        color='steelblue', alpha=0.5, edgecolor='white', label='Empirical'\n",
    "    )\n",
    "\n",
    "    ax.plot(t, res['dist'].pdf(t, *res['params']), 'r-', lw=2, label=f\"{res['name']} fit\")\n",
    "\n",
    "    ax.set_title(f\"{material}  (n={res['n']})\", fontweight='bold')\n",
    "    ax.set_ylabel('Density')\n",
    "    ax.set_xlim(0, MAX_AGE)\n",
    "    ax.set_ylim(0, max(counts) * 1.2)\n",
    "    ax.legend(fontsize=8)\n",
    "    ax.grid(axis='y', alpha=0.3)\n",
    "    ax.tick_params(axis='x', rotation=45)\n",
    "    if idx >= n_cols * (n_rows - 1):\n",
    "        ax.set_xlabel('Time to Failure (years)')\n",
    "\n",
    "for idx in range(n_materials, len(axes1)):\n",
    "    axes1[idx].set_visible(False)\n",
    "\n",
    "plt.suptitle('Empirical PDF + Fitted Distribution', fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# ── Step 3: CDF and Survival Function ────────────────────────────────────────\n",
    "fig2, axes2 = plt.subplots(n_rows, n_cols, figsize=(15, 10))\n",
    "axes2 = axes2.flatten()\n",
    "\n",
    "for idx, (material, res) in enumerate(fit_results.items()):\n",
    "    ax  = axes2[idx]\n",
    "    F_t = res['dist'].cdf(t, *res['params'])  # F(t)\n",
    "    S_t = 1 - F_t                              # S(t) = 1 - F(t)\n",
    "\n",
    "    ax.plot(t, F_t, 'b-', lw=2, label='F(t) — CDF')\n",
    "    ax.plot(t, S_t, 'r-', lw=2, label='S(t) — Survival')\n",
    "    ax.axhline(0.5, color='grey', lw=1, linestyle='--')\n",
    "\n",
    "    # Median survival (age where 50% of pipes have failed)\n",
    "    median_t = res['dist'].ppf(0.5, *res['params'])\n",
    "    ax.axvline(median_t, color='grey', lw=1, linestyle=':')\n",
    "    ax.text(median_t + 1, 0.52, f'median\\n{median_t:.0f} yr', fontsize=8, color='grey')\n",
    "\n",
    "    ax.set_title(f\"{material} — {res['name']}  (n={res['n']})\", fontweight='bold')\n",
    "    ax.set_ylabel('Probability')\n",
    "    ax.set_xlim(0, MAX_AGE)\n",
    "    ax.set_ylim(0, 1)\n",
    "    ax.legend(fontsize=8)\n",
    "    ax.grid(alpha=0.3)\n",
    "    ax.tick_params(axis='x', rotation=45)\n",
    "    if idx >= n_cols * (n_rows - 1):\n",
    "        ax.set_xlabel('Time (years)')\n",
    "\n",
    "for idx in range(n_materials, len(axes2)):\n",
    "    axes2[idx].set_visible(False)\n",
    "\n",
    "plt.suptitle('CDF and Survival Function  S(t) = 1 − F(t)', fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
