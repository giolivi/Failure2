   "source": [
    "installed1900 = conduitsA[conduitsA['Aanlegjaar'] > 1900]\n",
    "conduits_len = np.zeros(124)\n",
    "year = np.zeros(124)\n",
    "\n",
    "for i in range(124):\n",
    "    conduits_len[i] = installed1900[installed1900['Aanlegjaar']==1900+i]['Lengte'].sum()/1000 #km\n",
    "    year[i] = 1900 + i \n",
    "\n",
    "plt.plot(year, conduits_len)"
   ]
