   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Calcola il numero di materiali\n",
    "n_materials = len(cross_tab_age_mat.columns)\n",
    "n_cols = 3\n",
    "n_rows = (n_materials + n_cols - 1) // n_cols\n",
    "\n",
    "fig, axes = plt.subplots(n_rows, n_cols, figsize=(15, 10))\n",
    "axes = axes.flatten()\n",
    "\n",
    "for idx, materiale in enumerate(cross_tab_age_mat.columns):\n",
    "    ax = axes[idx]\n",
    "    \n",
    "    # Calcola le frequenze relative (percentuale)\n",
    "    frequenze_relative = (cross_tab_age_mat[materiale] / cross_tab_age_mat[materiale].sum()) * 100\n",
    "    \n",
    "    ax.bar(cross_tab_age_mat.index, frequenze_relative, color='steelblue', alpha=0.7)\n",
    "    ax.set_title(materiale, fontweight='bold')\n",
    "    ax.set_ylabel('Percentage (%)')\n",
    "    ax.set_ylim(0, max(frequenze_relative) * 1.1)  # Aggiungi un po' di spazio in alto\n",
    "    ax.grid(axis='y', alpha=0.3)\n",
    "    if idx >= n_cols * (n_rows - 1):\n",
    "        ax.set_xlabel('Age Classes')\n",
    "    ax.tick_params(axis='x', rotation=45)\n",
