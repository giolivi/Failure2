   "source": [
    "\n",
    "\n",
    "files = glob.glob('failures_*.csv')\n",
    "\n",
    "dfs = []\n",
    "\n",
    "for file in files:\n",
    "    df = pd.read_csv(file, sep=';')\n",
    "\n",
    "    name = os.path.splitext(os.path.basename(file))[0]\n",
    "    year = name.split('_')[-1]\n",
    "\n",
    "    df['Year'] = int(year)\n",
    "\n",
    "    dfs.append(df)\n",
    "\n",
    "big_df = pd.concat(dfs, axis=0, ignore_index=True)\n",
    "\n",
    "big_df.tail()"
   ]
  },
