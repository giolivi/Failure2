    "conduitsA_2010 = conduitsA[conduitsA['Aanlegjaar']<2010]\n",
    "conduitsA_2010_len = conduitsA_2010['Lengte'].sum()\n",
    "\n",
    "print(conduitsA_2010_len)\n",
