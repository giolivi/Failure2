    "print(\"\\n\" + \"=\"*70)\n",
    "print(\"IPOTESI 1: MATERIALE\")\n",
    "print(\"=\"*70)\n",
    " \n",
    "# Calcola statistiche per materiale\n",
    "material_stats = merged.groupby('failure_material')['age'].agg([\n",
    "    'count', 'mean', 'median', 'std', 'min', 'max'\n",
    "]).round(2).sort_values('mean', ascending=False)\n",
    " \n",
    "print(\"\\nStatistiche età di rottura per materiale:\")\n",
    "print(material_stats)\n",
    " \n",
    "# Visualizzazione 1: Box plot per materiale\n",
    "fig, ax = plt.subplots(figsize=(12, 6))\n",
    "merged.boxplot(column='age', by='failure_material', ax=ax)\n",
    "ax.set_xlabel('Materiale', fontsize=12)\n",
    "ax.set_ylabel('Età di rottura (anni)', fontsize=12)\n",
    "ax.set_title('IPOTESI 1: Distribuzione dell\\'Età per Materiale', fontsize=14, fontweight='bold')\n",
    "plt.suptitle('')\n",
    "plt.xticks(rotation=45, ha='right')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    " \n",
    "  \n",
    "# Visualizzazione 2: Heatmap materiale × frequenza\n",
    "fig, ax = plt.subplots(figsize=(12, 6))\n",
